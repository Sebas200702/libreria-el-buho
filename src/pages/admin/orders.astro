---
import { OrderTable } from '@/components/admin/OrderTable.tsx'
import AdminLayout from '@/layouts/AdminLayout.astro'

const supabase = Astro.locals.supabase
const user = Astro.locals.user

const { data: orders } = await supabase
	.from('orders')
	.select(
		'id, customer_name, customer_email, customer_phone, notes, status, total, created_at',
	)
	.order('created_at', { ascending: false })
---

<AdminLayout title="Pedidos — Admin" section="orders" user={user}>
  <div class="px-6 md:px-10 py-8" data-testid="orders-page">
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="label mb-2"> Pedidos</div>
        <h1 class="text-[36px] md:text-[44px] tracking-tight">Operaciones</h1>
      </div>
      <div class="mono text-[11px] uppercase tracking-[0.14em] text-muted">
        {orders?.length ?? 0} registros
      </div>
    </div>
    <OrderTable client:load initialOrders={orders ?? []} />
  </div>
</AdminLayout>
