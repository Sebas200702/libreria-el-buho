---
import { ProductManager } from '@/components/admin/ProductManager.tsx'
import AdminLayout from '@/layouts/AdminLayout.astro'

const supabase = Astro.locals.supabase
const user = Astro.locals.user
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL

const { data: books } = await supabase
	.from('books')
	.select('*')
	.order('created_at', { ascending: false })
---

<AdminLayout title="Libros — Admin" section="products" user={user}>
  <div class="px-6 md:px-10 py-8" data-testid="products-page">
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="label mb-2"> Catálogo</div>
        <h1 class="text-[36px] md:text-[44px] tracking-tight">Libros</h1>
      </div>
      <div class="mono text-[11px] uppercase tracking-[0.14em] text-muted">
        {books?.length ?? 0} títulos
      </div>
    </div>
    <ProductManager client:load initialBooks={books ?? []} supabaseUrl={supabaseUrl} />
  </div>
</AdminLayout>
