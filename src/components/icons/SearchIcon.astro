---
interface Props {
	class?: string
	width?: string | number
	height?: string | number
	strokeWidth?: string | number
}
const {
	class: className,
	width = '24',
	height = '24',
	strokeWidth = '2',
	...rest
} = Astro.props
---
<svg width={width} height={height} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={strokeWidth} class={className} {...rest}>
  <circle cx="11" cy="11" r="7" />
  <line x1="21" y1="21" x2="16.65" y2="16.65" />
</svg>
