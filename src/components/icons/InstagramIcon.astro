---
interface Props {
	class?: string
	width?: string | number
	height?: string | number
	strokeWidth?: string | number
}
const {
	class: className,
	width = '24',
	height = '24',
	strokeWidth = '2',
	...rest
} = Astro.props
---
<svg width={width} height={height} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={strokeWidth} class={className} {...rest}>
  <rect x="3" y="3" width="18" height="18" rx="5" />
  <circle cx="12" cy="12" r="4" />
  <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" />
</svg>
