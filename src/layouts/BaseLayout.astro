---
import Footer from '@/components/layout/Footer.astro'
import Header from '@/components/layout/Header.astro'
import '@/styles/global.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
	title?: string
	description?: string
	hideHeader?: boolean
	hideFooter?: boolean
}

const {
	title = 'Librería del Búho — Editorial independiente',
	description = 'Libros seleccionados, editados y distribuidos con precisión. Catálogo vivo, envío ágil.',
	hideHeader = false,
	hideFooter = false,
} = Astro.props

const cartCount = 0 // hydrated by island
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/logo-owl.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/logo-owl.png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500&family=Geist:wght@300;400;500;600&display=swap"
    />
    <ClientRouter />

  </head>
  <body>
    {!hideHeader && <Header cartCount={cartCount} />}
    <main class="relative z-10 min-h-[60vh]">
      <slot />
    </main>
    {!hideFooter && <Footer />}
  </body>
</html>
