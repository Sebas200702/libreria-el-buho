---
import '../styles/global.css';
import Sidebar from '../components/admin/Sidebar.astro';

interface Props {
  title?: string;
  section?: string;
  user?: { email?: string | null } | null;
}
const { title = 'Admin — Librería del Búho', section = 'dashboard', user } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500&family=Geist:wght@300;400;500;600&display=swap"
    />
  </head>
  <body class="min-h-screen">
    <div class="flex min-h-screen">
      <Sidebar current={section} userEmail={user?.email ?? null} />
      <main class="flex-1 min-w-0 ml-0 md:ml-[240px]">
        <slot />
      </main>
    </div>
  </body>
</html>
