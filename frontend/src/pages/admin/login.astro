---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LoginForm from '../../components/admin/LoginForm.tsx';

const next = new URL(Astro.request.url).searchParams.get('next') ?? '/admin';
---

<BaseLayout title="Admin — Acceso" hideFooter>
  <section class="min-h-[70vh] flex items-center justify-center px-6 py-16">
    <div class="w-full max-w-md">
      <div class="label mb-3">§ Panel interno</div>
      <h1 class="text-[36px] md:text-[44px] tracking-tight mb-2 leading-[1.05]">
        Acceso editorial
      </h1>
      <p class="text-[14px] text-[color:var(--color-muted)] mb-8">
        Inicia sesión para gestionar pedidos, catálogo e inventario.
      </p>
      <div class="card p-6 md:p-8">
        <LoginForm client:load next={next} />
      </div>
      <div class="mono text-[11px] uppercase tracking-[0.14em] text-[color:var(--color-muted-2)] mt-6 text-center">
        Crea usuarios desde Supabase → Auth → Users
      </div>
    </div>
  </section>
</BaseLayout>
