---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/shop/ProductCard.astro';
import { getServerSupabase } from '../lib/supabase/server';

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q')?.trim() ?? '';
const genre = url.searchParams.get('genre') ?? '';
const category = url.searchParams.get('category') ?? '';
const sort = url.searchParams.get('sort') ?? 'new';
const offers = url.searchParams.get('offers');

const supabase = getServerSupabase({ request: Astro.request, cookies: Astro.cookies });

let query = supabase
  .from('books')
  .select('id, slug, title, author, price, stock, genre, category, release_year, cover_image_path')
  .eq('published', true);

if (q) query = query.or(`title.ilike.%${q}%,author.ilike.%${q}%`);
if (genre) query = query.eq('genre', genre);
if (category) query = query.eq('category', category);
if (offers === '1') query = query.lte('price', 15000);

if (sort === 'new') query = query.order('release_year', { ascending: false });
else if (sort === 'price-asc') query = query.order('price', { ascending: true });
else if (sort === 'price-desc') query = query.order('price', { ascending: false });
else if (sort === 'title') query = query.order('title', { ascending: true });

const { data: books } = await query.limit(60);

const { data: allGenresRows } = await supabase
  .from('books')
  .select('genre')
  .eq('published', true)
  .not('genre', 'is', null);
const uniqueGenres = Array.from(
  new Set((allGenresRows ?? []).map((r) => (r as { genre: string }).genre)),
).sort();

const sorts = [
  { v: 'new', label: 'Más nuevos' },
  { v: 'title', label: 'Título A→Z' },
  { v: 'price-asc', label: 'Precio ↑' },
  { v: 'price-desc', label: 'Precio ↓' },
];
---

<BaseLayout title="Catálogo — Librería del Búho">
  <section class="mx-auto max-w-[1440px] px-6 pt-10 pb-6 border-b border-[color:var(--color-line)]">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <div class="label mb-2">§ Catálogo</div>
        <h1 class="text-[40px] md:text-[56px] tracking-tight">Todos los títulos</h1>
      </div>
      <div class="mono text-[11px] uppercase tracking-[0.14em] text-[color:var(--color-muted)]">
        Mostrando {books?.length ?? 0} {books?.length === 1 ? 'título' : 'títulos'}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-6 py-8 grid grid-cols-12 gap-8">
    <!-- FILTERS -->
    <aside class="col-span-12 md:col-span-3" data-testid="filters">
      <form method="get" class="space-y-6">
        <div>
          <div class="label mb-2">Buscar</div>
          <input
            type="text"
            name="q"
            value={q}
            placeholder="título o autor"
            class="input"
            data-testid="filter-search"
          />
        </div>

        <div>
          <div class="label mb-2">Género</div>
          <div class="flex flex-wrap gap-2">
            <button
              type="submit"
              name="genre"
              value=""
              class:list={[
                'chip cursor-pointer hover:border-[color:var(--color-ink)]',
                !genre && 'bg-[color:var(--color-ink)] text-[color:var(--color-paper)] border-[color:var(--color-ink)]',
              ]}
            >
              Todos
            </button>
            {
              uniqueGenres.map((g) => (
                <button
                  type="submit"
                  name="genre"
                  value={g}
                  class:list={[
                    'chip cursor-pointer hover:border-[color:var(--color-ink)]',
                    g === genre &&
                      'bg-[color:var(--color-ink)] text-[color:var(--color-paper)] border-[color:var(--color-ink)]',
                  ]}
                >
                  {g}
                </button>
              ))
            }
          </div>
        </div>

        <div>
          <div class="label mb-2">Ordenar</div>
          <select name="sort" class="input" data-testid="filter-sort">
            {sorts.map((s) => <option value={s.v} selected={s.v === sort}>{s.label}</option>)}
          </select>
        </div>

        <div>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="offers" value="1" checked={offers === '1'} class="accent-[color:var(--color-ink)]" />
            <span class="mono text-[11px] uppercase tracking-[0.14em]">Solo económicos ≤ $15.000</span>
          </label>
        </div>

        <button type="submit" class="btn btn-primary w-full justify-center" data-testid="filter-apply">
          Aplicar filtros
        </button>
        <a href="/catalog" class="mono text-[11px] uppercase tracking-[0.14em] text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)] block text-center">
          Limpiar
        </a>
      </form>
    </aside>

    <!-- RESULTS -->
    <div class="col-span-12 md:col-span-9" data-testid="catalog-results">
      <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
        {(books ?? []).map((b, i) => <ProductCard book={b} index={i} />)}
      </div>
      {
        (!books || books.length === 0) && (
          <div class="card p-12 text-center">
            <div class="mono text-[11px] uppercase tracking-[0.14em] text-[color:var(--color-muted)] mb-2">
              0 resultados
            </div>
            <div class="text-[18px]">Intenta con otro criterio o limpia los filtros.</div>
            <a href="/catalog" class="btn btn-ghost mt-5 inline-flex">Ver todo</a>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
