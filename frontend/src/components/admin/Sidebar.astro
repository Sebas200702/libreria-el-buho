---
import LogoutButton from './LogoutButton.tsx';

interface Props {
  current?: string;
  userEmail?: string | null;
}
const { current = '', userEmail = null } = Astro.props;

const items = [
  {
    key: 'dashboard',
    href: '/admin',
    label: 'Dashboard',
    icon: 'M3 13h8V3H3z M13 21h8V11h-8z M3 21h8v-6H3z M13 9h8V3h-8z',
  },
  {
    key: 'orders',
    href: '/admin/orders',
    label: 'Pedidos',
    icon: 'M3 7h18 M3 12h18 M3 17h18',
  },
  {
    key: 'products',
    href: '/admin/products',
    label: 'Libros',
    icon: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20 M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z',
  },
];
---

<aside
  class="fixed left-0 top-0 w-[240px] h-full bg-[color:var(--color-paper-2)] border-r border-[color:var(--color-line)] hidden md:flex flex-col z-30"
  data-testid="admin-sidebar"
>
  <div class="px-5 py-5 border-b border-[color:var(--color-line)]">
    <a href="/" class="flex items-center gap-2">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="14" stroke="#0A0A0A" stroke-width="2" fill="#F7F7F5" />
        <circle cx="11" cy="13" r="3" fill="#0A0A0A" />
        <circle cx="21" cy="13" r="3" fill="#0A0A0A" />
        <path d="M10 21 L16 19 L22 21" stroke="#0A0A0A" stroke-width="1.5" />
      </svg>
      <span class="text-[14px] font-medium tracking-tight">Librería del Búho</span>
    </a>
    <div class="mono text-[10px] uppercase tracking-[0.14em] text-[color:var(--color-muted-2)] mt-2">
      § Panel interno
    </div>
  </div>

  <nav class="flex-1 p-3 space-y-1">
    {
      items.map((it) => (
        <a
          href={it.href}
          class:list={[
            'flex items-center gap-2.5 px-3 py-2 rounded-[10px] text-[13px] transition-colors',
            current === it.key
              ? 'bg-[color:var(--color-ink)] text-[color:var(--color-paper)]'
              : 'text-[color:var(--color-ink)] hover:bg-[color:var(--color-paper-3)]',
          ]}
          data-testid={`sidebar-${it.key}`}
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="square">
            <path d={it.icon} />
          </svg>
          {it.label}
        </a>
      ))
    }
  </nav>

  <div class="p-3 border-t border-[color:var(--color-line)]">
    <div class="px-3 py-2 flex items-center justify-between">
      <div class="min-w-0">
        <div class="mono text-[10px] uppercase tracking-[0.14em] text-[color:var(--color-muted-2)]">
          Sesión
        </div>
        <div class="text-[12px] truncate" data-testid="admin-user-email">
          {userEmail ?? '—'}
        </div>
      </div>
      <LogoutButton client:load />
    </div>
    <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-[10px] text-[12px] text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)] hover:bg-[color:var(--color-paper-3)] transition-colors">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
        <path d="M15 3h6v6" /><path d="M10 14L21 3" /><path d="M21 14v7H3V3h7" />
      </svg>
      Ver tienda
    </a>
  </div>
</aside>

<!-- mobile bar -->
<div class="md:hidden fixed top-0 left-0 right-0 h-14 bg-[color:var(--color-paper-2)] border-b border-[color:var(--color-line)] z-30 flex items-center justify-between px-4">
  <a href="/admin" class="flex items-center gap-2">
    <svg width="20" height="20" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="16" r="14" stroke="#0A0A0A" stroke-width="2" fill="#F7F7F5" />
      <circle cx="11" cy="13" r="3" fill="#0A0A0A" />
      <circle cx="21" cy="13" r="3" fill="#0A0A0A" />
    </svg>
    <span class="text-[13px]">Búho · Admin</span>
  </a>
  <div class="flex items-center gap-1">
    {
      items.map((it) => (
        <a
          href={it.href}
          class:list={[
            'icon-btn',
            current === it.key && 'bg-[color:var(--color-ink)] text-[color:var(--color-paper)] border-[color:var(--color-ink)]',
          ]}
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
            <path d={it.icon} />
          </svg>
        </a>
      ))
    }
  </div>
</div>
<div class="md:hidden h-14"></div>
