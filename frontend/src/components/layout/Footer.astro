---
const year = new Date().getFullYear();
const logoUrl = import.meta.env.PUBLIC_LOGO_URL;
const whatsapp = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL;
const instagramHandle = import.meta.env.PUBLIC_INSTAGRAM_HANDLE;
---

<footer class="relative z-10 border-t border-[color:var(--color-line)] bg-[color:var(--color-paper-2)] mt-24">
  <div class="mx-auto max-w-[1440px] px-6 py-16 grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-5">
      <div class="flex items-center gap-3 mb-5">
        <img
          src={logoUrl}
          alt="Librería del Búho"
          width="44"
          height="44"
          class="w-11 h-11 rounded-full border border-[color:var(--color-line-2)] bg-white object-contain p-1"
        />
        <div>
          <div class="text-[18px] font-medium leading-none">Librería del Búho</div>
          <div class="mono text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-muted-2)] mt-1">
            Barranquilla · desde Colombia
          </div>
        </div>
      </div>
      <p class="text-[14px] max-w-sm leading-[1.6] text-[color:var(--color-muted)]">
        Una librería pequeña con muchos clásicos. Pedidos por WhatsApp,
        entregas en Barranquilla y alrededores.
      </p>

      <div class="flex items-center gap-3 mt-6">
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener"
          aria-label={`Instagram ${instagramHandle}`}
          class="icon-btn"
          data-testid="footer-ig"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" />
          </svg>
        </a>
        <a
          href={`https://wa.me/${whatsapp}`}
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
          class="icon-btn"
          data-testid="footer-wa"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487 2.981 1.287 2.981.858 3.518.803.537-.056 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="col-span-6 md:col-span-2">
      <div class="label mb-3">Tienda</div>
      <ul class="space-y-2 text-[14px]">
        <li><a href="/catalog" class="hover:underline" data-testid="footer-catalog">Catálogo</a></li>
        <li><a href="/catalog?sort=new" class="hover:underline">Novedades</a></li>
        <li><a href="/catalog?offers=1" class="hover:underline">Económicos</a></li>
        <li><a href="/cart" class="hover:underline">Mi pedido</a></li>
      </ul>
    </div>

    <div class="col-span-6 md:col-span-2">
      <div class="label mb-3">Géneros</div>
      <ul class="space-y-2 text-[14px]">
        <li><a href="/catalog?genre=Ficci%C3%B3n%20cl%C3%A1sica" class="hover:underline">Clásicos</a></li>
        <li><a href="/catalog?genre=Filosof%C3%ADa" class="hover:underline">Filosofía</a></li>
        <li><a href="/catalog?genre=Literatura%20colombiana" class="hover:underline">Colombiana</a></li>
        <li><a href="/catalog?genre=Teatro" class="hover:underline">Teatro</a></li>
        <li><a href="/catalog?genre=Infantil" class="hover:underline">Infantil</a></li>
      </ul>
    </div>

    <div class="col-span-12 md:col-span-3">
      <div class="label mb-3">Contacto</div>
      <ul class="space-y-2 text-[14px]">
        <li>
          <a
            href={`https://wa.me/${whatsapp}`}
            target="_blank"
            rel="noopener"
            class="hover:underline inline-flex items-center gap-1.5"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606"/></svg>
            Pedidos por WhatsApp
          </a>
        </li>
        <li>
          <a href={instagramUrl} target="_blank" rel="noopener" class="hover:underline">
            {instagramHandle} en Instagram
          </a>
        </li>
        <li class="text-[color:var(--color-muted)]">
          Entregas: Barranquilla y zonas aledañas
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[color:var(--color-line)]">
    <div class="mx-auto max-w-[1440px] px-6 py-5 flex flex-wrap items-center justify-between gap-3">
      <div class="mono text-[11px] uppercase tracking-[0.14em] text-[color:var(--color-muted-2)]">
        © {year} Librería del Búho — Barranquilla, Colombia
      </div>
      <div class="mono text-[11px] uppercase tracking-[0.14em] text-[color:var(--color-muted-2)]">
        Una librería pequeña con muchos clásicos
      </div>
    </div>
  </div>
</footer>
