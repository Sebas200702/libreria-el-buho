---
import CartButton from '../shop/CartButton.tsx';

interface Props {
  cartCount?: number;
}
const { cartCount = 0 } = Astro.props;
const path = new URL(Astro.request.url).pathname;
const logoUrl = import.meta.env.PUBLIC_LOGO_URL;
const whatsapp = import.meta.env.PUBLIC_WHATSAPP_NUMBER;

const nav = [
  { href: '/', label: 'Inicio' },
  { href: '/catalog', label: 'Catálogo' },
  { href: '/catalog?sort=new', label: 'Novedades' },
  { href: '/catalog?genre=Filosof%C3%ADa', label: 'Filosofía' },
  { href: '/catalog?genre=Literatura%20colombiana', label: 'Colombiana' },
];
---

<header
  class="sticky top-0 z-40 border-b border-[color:var(--color-line)] bg-[color:var(--color-paper)]/85 backdrop-blur"
  data-testid="site-header"
>
  <div class="mx-auto flex max-w-[1440px] items-center justify-between gap-6 px-5 md:px-6 py-3">
    <a href="/" class="flex items-center gap-2.5" data-testid="logo-link">
      <img
        src={logoUrl}
        alt="Librería del Búho"
        width="38"
        height="38"
        class="w-[38px] h-[38px] rounded-full border border-[color:var(--color-line-2)] bg-white object-contain p-[3px]"
        loading="eager"
      />
      <div class="leading-[1.05]">
        <div class="text-[15px] font-medium tracking-tight">Librería del Búho</div>
        <div class="mono text-[9px] uppercase tracking-[0.18em] text-[color:var(--color-muted-2)]">
          Barranquilla · por WhatsApp
        </div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Principal">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-[13px] rounded-[10px] transition-colors',
              path === item.href
                ? 'bg-[color:var(--color-ink)] text-[color:var(--color-paper)]'
                : 'text-[color:var(--color-ink)] hover:bg-[color:var(--color-paper-3)]',
            ]}
            data-testid={`nav-${item.label.toLowerCase()}`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/catalog"
        class="icon-btn"
        aria-label="Buscar"
        data-testid="search-btn"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </a>
      <a
        href={`https://wa.me/${whatsapp}`}
        target="_blank"
        rel="noopener"
        class="icon-btn hidden sm:inline-flex"
        aria-label="WhatsApp"
        data-testid="header-whatsapp"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.304-1.654a11.88 11.88 0 0 0 5.684 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413"/>
        </svg>
      </a>
      <CartButton client:load initialCount={cartCount} />
    </div>
  </div>
</header>
